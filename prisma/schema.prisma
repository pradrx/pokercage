generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// NextAuth models

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Application models

model User {
  id               String        @id @default(cuid())
  name             String?
  email            String?       @unique
  emailVerified    DateTime?
  image            String?
  username         String?
  usernameLower    String?       @unique
  venmo            String?
  zelle            String?
  cashapp          String?
  paypal           String?
  accounts         Account[]
  sessions         Session[]
  games            Game[]
  groupMemberships GroupMember[]
  groupInvites     GroupInvite[]
  gameEvents       GameEvent[]
  createdAt        DateTime      @default(now())
}

enum GroupRole {
  OWNER
  ADMIN
  MEMBER
}

model Group {
  id        String        @id @default(cuid())
  name      String
  members   GroupMember[]
  games     Game[]
  invites   GroupInvite[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model GroupInvite {
  id        String    @id @default(cuid())
  code      String    @unique
  groupId   String
  group     Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy String
  creator   User      @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([groupId])
  @@index([code])
}

model GroupMember {
  id        String    @id @default(cuid())
  name      String
  groupId   String
  group     Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  role      GroupRole @default(MEMBER)
  venmo     String?
  zelle     String?
  cashapp   String?
  paypal    String?
  players   Player[]
  createdAt DateTime  @default(now())

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
}

enum GameStatus {
  ACTIVE
  COMPLETED
}

enum GameEventType {
  GAME_CREATED
  GAME_COMPLETED
  GAME_REOPENED
  PLAYER_ADDED
  PLAYER_REMOVED
  BUYIN_ADDED
  BUYIN_REMOVED
  CASHOUT_SET
  CASHOUT_CHANGED
  CASHOUT_CLEARED
}

model Game {
  id         String     @id @default(cuid())
  name       String
  date       DateTime
  status     GameStatus @default(ACTIVE)
  shareToken String     @unique @default(cuid())
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupId    String?
  group      Group?     @relation(fields: [groupId], references: [id], onDelete: SetNull)
  players    Player[]
  events     GameEvent[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([userId])
  @@index([shareToken])
  @@index([groupId])
}

model Player {
  id            String       @id @default(cuid())
  name          String
  cashout       Float?
  gameId        String
  game          Game         @relation(fields: [gameId], references: [id], onDelete: Cascade)
  groupMemberId String?
  groupMember   GroupMember? @relation(fields: [groupMemberId], references: [id], onDelete: SetNull)
  buyins        Buyin[]

  @@index([gameId])
  @@index([groupMemberId])
}

model Buyin {
  id        String   @id @default(cuid())
  amount    Float
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([playerId])
}

model GameEvent {
  id         String        @id @default(cuid())
  type       GameEventType
  gameId     String
  game       Game          @relation(fields: [gameId], references: [id], onDelete: Cascade)
  actorId    String?
  actor      User?         @relation(fields: [actorId], references: [id], onDelete: SetNull)
  actorName  String?
  playerName String?
  detail     String
  oldValue   String?
  newValue   String?
  createdAt  DateTime      @default(now())

  @@index([gameId, createdAt])
  @@index([actorId])
}
