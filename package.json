{
  "name": "pokercage",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": ". .env && DEV_AUTH=true NEXT_PUBLIC_DEV_AUTH=true DATABASE_URL=$TEST_DATABASE_URL next dev",
    "dev:prod": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:seed": ". .env && DATABASE_URL=$TEST_DATABASE_URL tsx prisma/seed.ts",
    "db:migrate": ". .env && DIRECT_DATABASE_URL=$TEST_DIRECT_DATABASE_URL npx prisma migrate deploy",
    "db:migrate:prod": "npx prisma migrate deploy"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@base-ui/react": "^1.3.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "lucide-react": "^1.7.0",
    "nanoid": "^5.1.7",
    "next": "16.2.1",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "prisma": "^7.6.0",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
